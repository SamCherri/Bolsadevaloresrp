generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INVESTOR
  ISSUER
  COLLABORATOR
  ADMIN
}

enum AssetStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  FROZEN
  REJECTED
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  EXECUTED
  REJECTED
  CANCELLED
}

enum CandleTimeframe {
  M1
  M5
  H1
}

enum ExchangeType {
  DEPOSIT
  WITHDRAW
}

enum ExchangeStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole @default(INVESTOR)
  failedLoginAttempts Int @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions          Session[]
  wallet            Wallet?
  issuedAssets      Asset[]            @relation("AssetIssuer")
  assetApprovals    AssetApproval[]    @relation("AssetApprover")
  orders            Order[]
  exchangeOps       ExchangeOperation[] @relation("ExchangeUser")
  handledExchangeOps ExchangeOperation[] @relation("ExchangeCollaborator")
  auditLogs         AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Decimal  @default(10000) @db.Decimal(18, 4)
  reservedBalance Decimal  @default(0) @db.Decimal(18, 4)
  holdings        Holding[]
  orders          Order[]
  exchangeOps     ExchangeOperation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Asset {
  id                String      @id @default(cuid())
  ticker            String      @unique
  name              String
  description       String
  issuerId          String
  issuer            User        @relation("AssetIssuer", fields: [issuerId], references: [id])
  initialPrice      Decimal     @db.Decimal(18, 4)
  currentPrice      Decimal     @db.Decimal(18, 4)
  totalSupply       Int
  circulatingSupply Int
  feePercent        Decimal     @db.Decimal(6, 2)
  reservePercent    Decimal     @db.Decimal(6, 2)
  reserveFundValue  Decimal     @default(0) @db.Decimal(18, 4)
  fundPurpose       String
  status            AssetStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  approvals AssetApproval[]
  orders    Order[]
  holdings  Holding[]
  trades    Trade[]
  candles   Candle[]

  @@index([status, updatedAt])
  @@index([status, currentPrice])
}

model AssetApproval {
  id         String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  adminId     String?
  admin       User?    @relation("AssetApprover", fields: [adminId], references: [id])
  approved    Boolean?
  notes       String?
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
}

model Holding {
  id           String   @id @default(cuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  quantity      Int
  averagePrice  Decimal  @db.Decimal(18, 4)
  updatedAt     DateTime @updatedAt

  @@unique([walletId, assetId])
}

model Order {
  id         String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId    String
  wallet      Wallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        OrderType
  quantity    Int
  unitPrice   Decimal     @db.Decimal(18, 4)
  totalValue  Decimal     @db.Decimal(18, 4)
  status      OrderStatus @default(EXECUTED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  trades      Trade[]
}

model Trade {
  id        String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantity   Int
  price      Decimal  @db.Decimal(18, 4)
  value      Decimal  @db.Decimal(18, 4)
  createdAt  DateTime @default(now())

  @@index([assetId, createdAt(sort: Desc)])
}

model Candle {
  id         String          @id @default(cuid())
  assetId     String
  asset       Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timeframe   CandleTimeframe
  timestamp   DateTime
  open        Decimal         @db.Decimal(18, 4)
  high        Decimal         @db.Decimal(18, 4)
  low         Decimal         @db.Decimal(18, 4)
  close       Decimal         @db.Decimal(18, 4)
  volume      Decimal         @db.Decimal(18, 4)

  @@unique([assetId, timeframe, timestamp])
}

model ExchangeOperation {
  id                     String         @id @default(cuid())
  type                   ExchangeType
  status                 ExchangeStatus @default(PENDING)
  userId                 String
  user                   User           @relation("ExchangeUser", fields: [userId], references: [id], onDelete: Cascade)
  walletId               String
  wallet                 Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  collaboratorId         String?
  collaborator           User?          @relation("ExchangeCollaborator", fields: [collaboratorId], references: [id])
  amountGameCurrency     Decimal        @db.Decimal(18, 4)
  amountPlatformCurrency Decimal        @db.Decimal(18, 4)
  exchangeRate           Decimal        @db.Decimal(18, 6)
  reservedAmount         Decimal        @default(0) @db.Decimal(18, 4)
  wasRefunded            Boolean        @default(false)
  expiresAt              DateTime
  processedAt            DateTime?
  notes                  String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@index([status, createdAt(sort: Desc)])
  @@index([walletId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
}
